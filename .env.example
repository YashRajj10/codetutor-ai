# ============================================================
# CodeTutor AI — Environment Variables
# ============================================================
# Setup:
#   cp .env.example .env
#   Fill in your values, then run: streamlit run app.py
# ============================================================

# ---- REQUIRED -----------------------------------------------

# Google Gemini API key (FREE — no credit card needed)
# Get yours at: https://aistudio.google.com/app/apikey
# Free model used: gemini-2.5-flash-lite (stable free tier, ~1000 req/day)
GOOGLE_API_KEY=your_google_api_key_here

# ---- OPTIONAL (FastAPI backend only) ------------------------

# Comma-separated frontend origins allowed for CORS.
# Default is localhost for local dev. Set to your domain in production.
ALLOWED_ORIGINS=http://localhost:3000

# ---- SYSTEM DEPENDENCY (not a Python package) ---------------
# pytesseract requires Tesseract OCR installed at the OS level.
#   Ubuntu/Debian:  sudo apt install tesseract-ocr
#   macOS:          brew install tesseract
#   Windows:        https://github.com/UB-Mannheim/tesseract/wiki
